{
  "name": "teafi-bot",
  "version": "1.0.0",
  "description": "Discord bot for TeaFi Program",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "deploy": "bun run src/bot/deploy-commands.ts",
    "ai:init": "bun run src/scripts/init-vector-store.ts",
    "send-guide": "bun run src/scripts/send-guide.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "discord.js": "^14.16.0",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.9.2",
    "node-cron": "^4.2.1",
    "openai": "^4.70.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "discord.js": ">=14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "discord",
    "teafi",
    "bot",
    "openai"
  ],
  "license": "MIT"
}
