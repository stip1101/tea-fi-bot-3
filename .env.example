# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_guild_id_for_dev

# Database (REQUIRED)
POSTGRES_USER=teafi
POSTGRES_PASSWORD=
POSTGRES_DB=teafi_bot
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis (REQUIRED)
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# Channels
REVIEW_CHANNEL_ID=
TASK_LOG_CHANNEL_ID=
WORK_CHANNEL_ID=
LOCAL_LEAD_REVIEW_CHANNEL_ID=

# Roles
ADMIN_ROLE_ID=                    # comma-separated for multiple roles
LOCAL_LEAD_ROLE_ID=
SPROUT_LEAF_ROLE_ID=
GREEN_LEAF_ROLE_ID=
GOLDEN_LEAF_ROLE_ID=

# Monthly Reward Pool
MONTHLY_POOL=600000

# AI Helper
AMB_CHAT_CHANNEL_ID=
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=

# AI Helper Settings (optional)
AI_HELPER_ENABLED=true
AI_HELPER_MODEL=gpt-4o-mini
AI_HELPER_MAX_TOKENS=500
AI_HELPER_RATE_LIMIT_REQUESTS=10
AI_HELPER_RATE_LIMIT_WINDOW=60
AI_HELPER_COOLDOWN_SECONDS=5

# AI Work Analyzer (optional)
AI_ANALYZER_MODEL=gpt-4o-mini

# Twitter Scraper
TWITTER_COOKIES=
TWITTER_BEARER_TOKEN=
